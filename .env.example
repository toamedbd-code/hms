APP_NAME=HMS
APP_VERSION=2.0.0
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
INVOICE_FOOTER_FALLBACK_LINE="Powered By: www.toamedit.com Support: 01919-592638"
WEB_SETTING_CACHE_TTL_SECONDS=300

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hms
DB_USERNAME=root
DB_PASSWORD=

# Attendance integration defaults
ATTENDANCE_SCHEDULED_START=09:00
ATTENDANCE_SCHEDULED_END=17:00
ATTENDANCE_LATE_THRESHOLD_MINUTES=60
ATTENDANCE_OVERTIME_THRESHOLD_MINUTES=60
ATTENDANCE_LATE_DEDUCTION_PER_HOUR=200
ATTENDANCE_OVERTIME_RATE_PER_HOUR=300

# Toggle subscription enforcement: when true, inactive subscription blocks admin login and redirects
# admins to the bKash settings/payment page. Set to false to disable enforcement during development.
SUBSCRIPTION_ENFORCE=true

# Subscription plan amounts (in your currency)
SUBSCRIPTION_MONTHLY_AMOUNT=2000
SUBSCRIPTION_YEARLY_AMOUNT=20000
SUBSCRIPTION_DEFAULT_PERIOD=monthly

# bKash merchant settings (fill with your merchant account details)
BKASH_MERCHANT_ACCOUNT=
BKASH_API_URL=https://api.bkash.example.com
BKASH_API_KEY=

# Payment feature toggle: set to false to disable payment/public flows quickly
# Set to true (or 1) to allow payments; set to false to disable.
PAYMENT_ENABLED=true
# Optional descriptive mode flag
PAYMENT_MODE=on
