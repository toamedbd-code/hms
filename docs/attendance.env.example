# Attendance integration example env values
ATTENDANCE_SCHEDULED_START=09:00
ATTENDANCE_SCHEDULED_END=17:00
ATTENDANCE_LATE_THRESHOLD_MINUTES=60
ATTENDANCE_OVERTIME_THRESHOLD_MINUTES=60
ATTENDANCE_LATE_DEDUCTION_PER_HOUR=200
ATTENDANCE_OVERTIME_RATE_PER_HOUR=300

# Google public holiday sync (Bangladesh by default)
ATTENDANCE_GOOGLE_HOLIDAYS_ENABLED=true
ATTENDANCE_GOOGLE_HOLIDAY_COUNTRY=bd
# Keep this URL quoted so # is not treated as a comment by dotenv parser
ATTENDANCE_GOOGLE_HOLIDAY_ICS_URL=https://calendar.google.com/calendar/ical/en.bd%23holiday%40group.v.calendar.google.com/public/basic.ics

# Weekly holidays by PHP weekday index (0=Sun ... 6=Sat)
ATTENDANCE_WEEKLY_HOLIDAYS=5,6
